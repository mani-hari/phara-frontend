# PariharaOnline storefront — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# NEXT_PUBLIC_* are exposed to the browser (safe to be public).
# All others are server-only secrets — keep them out of client code and git.

# ── Site ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=PariharaOnline
NEXT_PUBLIC_SITE_URL=https://pariharaonline.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_REGION=in
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com            # comma-separated admin emails

# ── Medusa backend (Medusa Cloud) ───────────────────────────────────────────
MEDUSA_BACKEND_URL=https://your-store.medusajs.app
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://your-store.medusajs.app
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_key   # browser-safe store key
MEDUSA_ADMIN_API_KEY=sk_your_admin_key                # SECRET — server only; admin scripts (handle/media updates)
MEDUSA_CLOUD_S3_HOSTNAME=s3.us-east-1.amazonaws.com   # product image host (next/image remotePatterns)
MEDUSA_CLOUD_S3_PATHNAME=/medusajs.cloud-data-prod-use1-xxxxx/

# ── Payments ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret        # SECRET
NEXT_PUBLIC_PAYPAL_SANDBOX=false                      # "true" to use PayPal sandbox
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret          # SECRET
NEXT_PUBLIC_STRIPE_KEY=                               # legacy/optional
NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=
NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=

# ── Ask Parihara AI chat ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key                     # SECRET — Anthropic API (via Vercel AI SDK)

# ── Auth (NextAuth + OAuth providers) ────────────────────────────────────────
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32  # SECRET
NEXTAUTH_URL=https://pariharaonline.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret        # SECRET
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret    # SECRET

# ── Analytics ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=your_clarity_id

# ── Misc ──────────────────────────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key      # SECRET — currency conversion (optional)
REVALIDATE_SECRET=your_revalidate_secret              # SECRET — Next.js on-demand revalidation
