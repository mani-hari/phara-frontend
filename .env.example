# ===========================================
# PariharaOnline - Environment Configuration
# ===========================================

# Medusa Cloud Configuration
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://your-medusa-cloud-url.medusajs.app
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_key
MEDUSA_BACKEND_URL=https://your-medusa-cloud-url.medusajs.app
NEXT_PUBLIC_DEFAULT_REGION=us

# PayPal Configuration (International Payments - USD)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Razorpay Configuration (India Payments - INR)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Site Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=https://pariharaonline.com
NEXT_PUBLIC_SITE_NAME=PariharaOnline

# Google Analytics 4
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_ID=your_clarity_id

# Medusa Cloud S3 (for image optimization)
MEDUSA_CLOUD_S3_HOSTNAME=s3.us-east-1.amazonaws.com
MEDUSA_CLOUD_S3_PATHNAME=/medusajs.cloud-data-prod-use1-xxxxx/

# Stripe (legacy - optional)
NEXT_PUBLIC_STRIPE_KEY=

# Revalidation
REVALIDATE_SECRET=supersecret

# Currency API (optional - defaults to static rates)
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key
