# Medusa Cloud Configuration
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://your-medusa-cloud-url.medusajs.com
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_key

# PayPal Configuration (International Payments)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Razorpay Configuration (India Payments)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://pariharaonline.com
NEXT_PUBLIC_SITE_NAME=PariharaOnline

# Currency API (for live exchange rates - optional, defaults to static rates)
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key
